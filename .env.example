# Copy to .env and fill in your values
# AWS credentials: configure via aws cli, IAM role, or environment variables

# Redshift (provisioned)
REDSHIFT_HOST=your-cluster.xxxx.region.redshift.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DATABASE=dev
REDSHIFT_USER=awsuser
REDSHIFT_PASS=your-password

# Redshift Serverless (optional — used for dbt examples)
REDSHIFT_SERVERLESS_HOST=your-workgroup.account-id.region.redshift-serverless.amazonaws.com

# S3 Staging (must be same region as Redshift)
STAGING_BUCKET=your-staging-bucket
STAGING_IAM_ROLE=arn:aws:iam::123456789012:role/YourRedshiftS3Role
STAGING_REGION=us-east-1
